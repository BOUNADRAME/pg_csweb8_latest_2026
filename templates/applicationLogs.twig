{% extends "base.twig" %}
{% block resources %}
    <style>
        .log-badge { font-size: 0.8em; font-weight: 600; }
        .log-stats-bar { display: flex; gap: 0.5rem; flex-wrap: wrap; align-items: center; }
        .log-stats-bar .badge { font-size: 0.85em; padding: 0.4em 0.7em; }
        .log-filter-bar { display: flex; gap: 0.5rem; flex-wrap: wrap; align-items: flex-end; margin-bottom: 1rem; }
        .log-filter-bar .form-group { margin-bottom: 0; }
        .log-filter-bar label { font-size: 0.8em; font-weight: 600; margin-bottom: 0.15rem; display: block; }
        .log-filter-bar select, .log-filter-bar input { font-size: 0.85em; height: 32px; }
        #logs-table tbody tr { cursor: pointer; }
        #log-detail-context { background: #f1f3f5; padding: 1rem; border-radius: 4px; max-height: 350px; overflow: auto; font-size: 0.82em; white-space: pre-wrap; word-break: break-word; }
        #log-detail-message { background: #fff3cd; padding: 0.75rem; border-radius: 4px; white-space: pre-wrap; word-break: break-word; font-size: 0.85em; margin-bottom: 0.75rem; }
    </style>
{% endblock %}
{% block navSettings %}
    {% if is_granted('ROLE_SETTINGS_ALL') == true %}
        <li id="settings-nav-item" class="nav-item active">
            <a class="nav-link collapsed" href="#" data-toggle="collapse" data-target="#collapseSettings"
               aria-expanded="true" aria-controls="collapseSettings">
                <i class="fas fa-fw fa-cog"></i>
                <span>Settings</span>
            </a>
            <div id="collapseSettings" class="collapse show" aria-labelledby="headingSettings" data-parent="#side-menu">
                <div class="bg-white collapse-inner rounded">
                    <a class="collapse-item" href="{{ path('dataSettings') }}">
                        <i class="fas fa-fw fa-database"></i>
                        Data</a>
                    <a class="collapse-item" href="{{ path('backup') }}">
                        <i class="fas fa-fw fa-hdd"></i>
                        Backup</a>
                    <a class="collapse-item active" href="{{ path('applicationLogs') }}">
                        <i class="fas fa-fw fa-clipboard-list"></i>
                        Logs</a>
                </div>
            </div>
        </li>
    {% endif %}
{% endblock %}
{% block content %}
    <div class="row">
        <div class="col-12">
            <div id="alert" class="alert-placeholder-cspro alert-margin-cspro"></div>
        </div>
    </div>
    <div class="row">
        <div class="col-12">
            <div class="card shadow mb-4">
                <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between">
                    <h6 class="m-0 font-weight-bold text-primary"><i class="fas fa-clipboard-list"></i> Application Logs</h6>
                    <div class="log-stats-bar" id="log-stats-bar">
                        <i class="fas fa-spinner fa-spin text-muted"></i>
                    </div>
                </div>
                <div class="card-body">
                    {# ── Filters ── #}
                    <div class="log-filter-bar">
                        <div class="form-group">
                            <label for="filter-channel">Channel</label>
                            <select id="filter-channel" class="form-control form-control-sm">
                                <option value="">All</option>
                                <option value="app">app</option>
                                <option value="request">request</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label for="filter-level">Level</label>
                            <select id="filter-level" class="form-control form-control-sm">
                                <option value="">All</option>
                                <option value="EMERGENCY">EMERGENCY</option>
                                <option value="CRITICAL">CRITICAL</option>
                                <option value="ERROR">ERROR</option>
                                <option value="WARNING">WARNING</option>
                                <option value="NOTICE">NOTICE</option>
                                <option value="INFO">INFO</option>
                                <option value="DEBUG">DEBUG</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label for="filter-date-from">From</label>
                            <input type="date" id="filter-date-from" class="form-control form-control-sm">
                        </div>
                        <div class="form-group">
                            <label for="filter-date-to">To</label>
                            <input type="date" id="filter-date-to" class="form-control form-control-sm">
                        </div>
                        <div class="form-group">
                            <button type="button" class="btn btn-primary btn-sm" id="btn-filter"><i class="fas fa-filter"></i> Filter</button>
                            <button type="button" class="btn btn-outline-secondary btn-sm" id="btn-reset"><i class="fas fa-undo"></i> Reset</button>
                        </div>
                        <div class="form-group ml-auto">
                            <button type="button" class="btn btn-secondary btn-sm mr-1" id="btn-refresh"><i class="fas fa-sync-alt"></i> Refresh</button>
                            <button type="button" class="btn btn-warning btn-sm mr-1" id="btn-delete-filtered" disabled><i class="fas fa-eraser"></i> Delete Filtered</button>
                            <button type="button" class="btn btn-danger btn-sm" id="btn-purge-all"><i class="fas fa-trash-alt"></i> Purge All</button>
                        </div>
                    </div>
                    {# ── DataTable ── #}
                    <div class="table-responsive">
                        <table id="logs-table" class="table table-sm table-striped table-bordered table-hover" style="width:100%">
                            <thead>
                                <tr>
                                    <th style="width:60px">ID</th>
                                    <th style="width:90px">Channel</th>
                                    <th style="width:100px">Level</th>
                                    <th>Message</th>
                                    <th style="width:160px">Date</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
{% block modal %}
    {# ── Detail Modal ── #}
    <div id="log-detail-modal" class="modal fade" role="dialog" aria-labelledby="log-detail-label">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="log-detail-label"><i class="fas fa-info-circle"></i> Log Detail <span id="log-detail-id" class="badge badge-secondary"></span></h5>
                    <button type="button" class="close" data-dismiss="modal">&times;</button>
                </div>
                <div class="modal-body">
                    <div class="mb-2">
                        <strong>Channel:</strong> <span id="log-detail-channel"></span>
                        &nbsp;&nbsp;<strong>Level:</strong> <span id="log-detail-level"></span>
                        &nbsp;&nbsp;<strong>Date:</strong> <span id="log-detail-date"></span>
                    </div>
                    <div><strong>Message:</strong></div>
                    <div id="log-detail-message"></div>
                    <div><strong>Context:</strong></div>
                    <pre id="log-detail-context"></pre>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary btn-sm" data-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>

    {# ── Purge All Modal ── #}
    <div id="purge-all-modal" class="modal fade" role="dialog" aria-labelledby="purge-all-label">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title" id="purge-all-label"><i class="fas fa-exclamation-triangle"></i> Purger tous les logs</h5>
                    <button type="button" class="close text-white" data-dismiss="modal">&times;</button>
                </div>
                <div class="modal-body">
                    <p>Cette action va supprimer d&eacute;finitivement <strong>TOUTES</strong> les entr&eacute;es de log (<strong><span id="purge-total-count">0</span></strong> entr&eacute;es).</p>
                    <div class="alert alert-danger mb-0">
                        <i class="fas fa-exclamation-triangle"></i> <strong>Action irr&eacute;versible</strong> &mdash; les logs supprim&eacute;s ne pourront pas &ecirc;tre r&eacute;cup&eacute;r&eacute;s.
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal"><i class="fas fa-times"></i> Annuler</button>
                    <button type="button" class="btn btn-danger" id="confirm-purge-btn"><i class="fas fa-trash-alt"></i> Supprimer tout</button>
                </div>
            </div>
        </div>
    </div>

    {# ── Delete Filtered Modal ── #}
    <div id="delete-filtered-modal" class="modal fade" role="dialog" aria-labelledby="delete-filtered-label">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-warning">
                    <h5 class="modal-title" id="delete-filtered-label"><i class="fas fa-eraser"></i> Supprimer les logs filtr&eacute;s</h5>
                    <button type="button" class="close" data-dismiss="modal">&times;</button>
                </div>
                <div class="modal-body">
                    <p>Cette action va supprimer les entr&eacute;es correspondant aux filtres actifs :</p>
                    <ul id="delete-filtered-summary"></ul>
                    <div class="alert alert-warning mb-0">
                        <i class="fas fa-exclamation-triangle"></i> <strong>Action irr&eacute;versible.</strong>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal"><i class="fas fa-times"></i> Annuler</button>
                    <button type="button" class="btn btn-warning" id="confirm-delete-filtered-btn"><i class="fas fa-eraser"></i> Supprimer</button>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
{% block scripts %}
    <script>
        "use strict";

        function showAlert(message, alertStyle) {
            $("#alert").replaceWith("<div id='alert' class='" + alertStyle + " alert-margin-cspro'>" + message + "</div>");
            $("#alert").show();
        }

        function escapeHtml(str) {
            if (!str) return "";
            return String(str).replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
        }

        function levelBadge(level) {
            var cls = "badge-secondary";
            switch (level) {
                case "EMERGENCY": case "CRITICAL": cls = "badge-dark"; break;
                case "ERROR":     cls = "badge-danger"; break;
                case "WARNING":   cls = "badge-warning"; break;
                case "NOTICE": case "INFO": cls = "badge-info"; break;
                case "DEBUG":     cls = "badge-secondary"; break;
            }
            return '<span class="badge log-badge ' + cls + '">' + escapeHtml(level) + '</span>';
        }

        $(document).ready(function () {
            var $body = $("body");
            $(document).ajaxStart(function () { $body.addClass("loading"); });
            $(document).ajaxComplete(function () { $body.removeClass("loading"); });

            // ═══════════════════════════════════════════
            // Stats badges
            // ═══════════════════════════════════════════
            var totalLogs = 0;

            function loadStats() {
                $.ajax({
                    type: "GET",
                    url: "{{ path('applicationLogsStats') }}",
                    dataType: "json",
                    success: function (data) {
                        totalLogs = data.total || 0;
                        var html = '<span class="badge badge-primary">Total: ' + totalLogs + '</span>';
                        var stats = data.stats || {};
                        var order = ["CRITICAL", "EMERGENCY", "ERROR", "WARNING", "INFO", "DEBUG"];
                        for (var i = 0; i < order.length; i++) {
                            var lvl = order[i];
                            if (stats[lvl]) {
                                html += ' ' + levelBadge(lvl).replace('>' + lvl + '<', '>' + lvl + ': ' + stats[lvl] + '<');
                            }
                        }
                        $("#log-stats-bar").html(html);
                    },
                    error: function (response) {
                        if (response.status === 401 || response.status === 405) {
                            window.location.href = "{{ path('logout') }}";
                        }
                        $("#log-stats-bar").html('<span class="text-danger">Failed to load stats</span>');
                    }
                });
            }
            loadStats();

            // ═══════════════════════════════════════════
            // DataTable (server-side)
            // ═══════════════════════════════════════════
            var logsTable = $("#logs-table").DataTable({
                processing: true,
                serverSide: true,
                ajax: {
                    url: "{{ path('applicationLogsData') }}",
                    data: function (d) {
                        d.channel = $("#filter-channel").val();
                        d.level = $("#filter-level").val();
                        d.dateFrom = $("#filter-date-from").val();
                        d.dateTo = $("#filter-date-to").val();
                    },
                    error: function (xhr) {
                        if (xhr.status === 401 || xhr.status === 405) {
                            window.location.href = "{{ path('logout') }}";
                        }
                    }
                },
                columns: [
                    { data: "id", className: "text-center" },
                    { data: "channel" },
                    {
                        data: "level_name",
                        render: function (data) { return levelBadge(data); }
                    },
                    {
                        data: "message",
                        render: function (data) {
                            var msg = escapeHtml(data);
                            if (msg.length > 150) msg = msg.substring(0, 150) + "...";
                            return '<small>' + msg + '</small>';
                        }
                    },
                    { data: "created_time" }
                ],
                order: [[0, "desc"]],
                pageLength: 25,
                lengthMenu: [10, 25, 50, 100],
                language: { emptyTable: "No log entries found.", processing: '<i class="fas fa-spinner fa-spin"></i> Loading...' }
            });

            // ═══════════════════════════════════════════
            // Filters
            // ═══════════════════════════════════════════
            function hasActiveFilters() {
                return $("#filter-channel").val() !== "" || $("#filter-level").val() !== "" ||
                       $("#filter-date-from").val() !== "" || $("#filter-date-to").val() !== "";
            }

            function updateDeleteFilteredBtn() {
                $("#btn-delete-filtered").prop("disabled", !hasActiveFilters());
            }

            $("#btn-filter").on("click", function () {
                logsTable.ajax.reload();
                loadStats();
                updateDeleteFilteredBtn();
            });

            $("#btn-reset").on("click", function () {
                $("#filter-channel").val("");
                $("#filter-level").val("");
                $("#filter-date-from").val("");
                $("#filter-date-to").val("");
                logsTable.ajax.reload();
                loadStats();
                updateDeleteFilteredBtn();
            });

            $("#btn-refresh").on("click", function () {
                logsTable.ajax.reload(null, false);
                loadStats();
            });

            // ═══════════════════════════════════════════
            // Row click → detail modal
            // ═══════════════════════════════════════════
            $("#logs-table tbody").on("click", "tr", function () {
                var data = logsTable.row(this).data();
                if (!data) return;
                var logId = data.id;

                $("#log-detail-id").text("#" + logId);
                $("#log-detail-channel").text("...");
                $("#log-detail-level").html(levelBadge("..."));
                $("#log-detail-date").text("...");
                $("#log-detail-message").text("Loading...");
                $("#log-detail-context").text("Loading...");
                $("#log-detail-modal").modal("show");

                $.ajax({
                    type: "GET",
                    url: "{{ path('applicationLogsDetail', {id: 0}) }}".replace("/0", "/" + logId),
                    dataType: "json",
                    success: function (row) {
                        $("#log-detail-channel").text(row.channel);
                        $("#log-detail-level").html(levelBadge(row.level_name));
                        $("#log-detail-date").text(row.created_time);
                        $("#log-detail-message").text(row.message);

                        var ctx = row.context || "";
                        try {
                            var parsed = JSON.parse(ctx);
                            ctx = JSON.stringify(parsed, null, 2);
                        } catch (e) {
                            // keep as-is
                        }
                        $("#log-detail-context").text(ctx || "(empty)");
                    },
                    error: function () {
                        $("#log-detail-message").text("Failed to load log detail.");
                        $("#log-detail-context").text("");
                    }
                });
            });

            // ═══════════════════════════════════════════
            // Purge All
            // ═══════════════════════════════════════════
            $("#btn-purge-all").on("click", function () {
                $("#purge-total-count").text(totalLogs);
                $("#purge-all-modal").modal("show");
            });

            $("#confirm-purge-btn").on("click", function () {
                $("#purge-all-modal").modal("hide");
                $.ajax({
                    type: "DELETE",
                    url: "{{ path('applicationLogsTruncate') }}",
                    dataType: "json",
                    success: function (data) {
                        showAlert(data.description, "alert alert-success");
                        logsTable.ajax.reload();
                        loadStats();
                    },
                    error: function (response) {
                        if (response.status === 401 || response.status === 405) {
                            window.location.href = "{{ path('logout') }}";
                        } else {
                            showAlert("Failed to purge logs.", "alert alert-danger");
                        }
                    }
                });
            });

            // ═══════════════════════════════════════════
            // Delete Filtered
            // ═══════════════════════════════════════════
            $("#btn-delete-filtered").on("click", function () {
                var summary = [];
                if ($("#filter-channel").val()) summary.push("<li>Channel: <strong>" + escapeHtml($("#filter-channel").val()) + "</strong></li>");
                if ($("#filter-level").val()) summary.push("<li>Level: <strong>" + escapeHtml($("#filter-level").val()) + "</strong></li>");
                if ($("#filter-date-to").val()) summary.push("<li>Before: <strong>" + escapeHtml($("#filter-date-to").val()) + "</strong></li>");
                if (summary.length === 0) return;
                $("#delete-filtered-summary").html(summary.join(""));
                $("#delete-filtered-modal").modal("show");
            });

            $("#confirm-delete-filtered-btn").on("click", function () {
                $("#delete-filtered-modal").modal("hide");
                var payload = {};
                if ($("#filter-channel").val()) payload.channel = $("#filter-channel").val();
                if ($("#filter-level").val()) payload.level = $("#filter-level").val();
                if ($("#filter-date-to").val()) payload.dateTo = $("#filter-date-to").val();

                $.ajax({
                    type: "DELETE",
                    url: "{{ path('applicationLogsDeleteFiltered') }}",
                    contentType: "application/json",
                    data: JSON.stringify(payload),
                    dataType: "json",
                    success: function (data) {
                        showAlert(data.description, "alert alert-success");
                        logsTable.ajax.reload();
                        loadStats();
                    },
                    error: function (response) {
                        if (response.status === 401 || response.status === 405) {
                            window.location.href = "{{ path('logout') }}";
                        } else {
                            var msg = "Failed to delete filtered logs.";
                            try { msg = JSON.parse(response.responseText).description; } catch (e) {}
                            showAlert(msg, "alert alert-danger");
                        }
                    }
                });
            });
        });
    </script>
{% endblock %}
