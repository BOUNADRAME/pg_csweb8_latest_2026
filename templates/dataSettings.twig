            // Breakout Logs Viewer (v2 — master-detail + pro modal)
            (function () {
                var logsTable = null;
                var allLogs = [];
                var allDictionaries = [];
                var selectedDict = "";
                var currentLogContent = "";

                function escapeHtml(str) {
                    var div = document.createElement("div");
                    div.appendChild(document.createTextNode(str));
                    return div.innerHTML;
                }

                function formatSize(bytes) {
                    if (bytes === 0) return "0 B";
                    var k = 1024;
                    var sizes = ["B", "KB", "MB", "GB"];
                    var i = Math.floor(Math.log(bytes) / Math.log(k));
                    return parseFloat((bytes / Math.pow(k, i)).toFixed(1)) + " " + sizes[i];
                }

                // --- Sidebar ---

                function buildDictCounts() {
                    var counts = {};
                    for (var i = 0; i < allLogs.length; i++) {
                        var d = allLogs[i].dictName;
                        counts[d] = (counts[d] || 0) + 1;
                    }
                    return counts;
                }

                function renderDictList() {
                    var counts = buildDictCounts();
                    var html = '<a href="#" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center' +
                        (selectedDict === "" ? " active" : "") + '" data-dict="">' +
                        'All Dictionaries <span class="badge badge-pill ' +
                        (selectedDict === "" ? "badge-light" : "badge-primary") + '">' + allLogs.length + '</span></a>';
                    for (var i = 0; i < allDictionaries.length; i++) {
                        var d = allDictionaries[i];
                        var isActive = (selectedDict === d);
                        var cnt = counts[d] || 0;
                        html += '<a href="#" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center' +
                            (isActive ? " active" : "") + '" data-dict="' + escapeHtml(d) + '">' +
                            escapeHtml(d) + ' <span class="badge badge-pill ' +
                            (isActive ? "badge-light" : "badge-primary") + '">' + cnt + '</span></a>';
                    }
                    $("#logs-dict-list").html(html);
                }

                // --- Logs Table ---

                function renderLogsTable() {
                    if (logsTable) {
                        logsTable.destroy();
                        logsTable = null;
                    }

                    var filtered = selectedDict === "" ? allLogs : allLogs.filter(function (l) {
                        return l.dictName === selectedDict;
                    });

                    // Update panel header
                    $("#logs-panel-title").text(selectedDict === "" ? "All Dictionaries" : escapeHtml(selectedDict));
                    $("#logs-panel-summary").text(filtered.length + " log file" + (filtered.length !== 1 ? "s" : ""));

                    var tbody = $("#breakout-logs-body");
                    tbody.empty();
                    var rows = "";
                    for (var i = 0; i < filtered.length; i++) {
                        var log = filtered[i];
                        var badge = log.type === "manual"
                            ? '<span class="badge badge-warning">Manual</span>'
                            : '<span class="badge badge-primary">Scheduled</span>';
                        rows += '<tr>' +
                            '<td><input type="checkbox" class="log-select" value="' + escapeHtml(log.filename) + '"></td>' +
                            '<td>' + escapeHtml(log.dictName) + '</td>' +
                            '<td><small>' + escapeHtml(log.filename) + '</small></td>' +
                            '<td>' + badge + '</td>' +
                            '<td>' + escapeHtml(log.date) + '</td>' +
                            '<td>' + formatSize(log.size) + '</td>' +
                            '<td>' +
                                '<button class="btn btn-xs btn-info view-log-btn mr-1" data-file="' + escapeHtml(log.filename) + '" data-dict="' + escapeHtml(log.dictName) + '" data-type="' + escapeHtml(log.type) + '" data-date="' + escapeHtml(log.date) + '" data-size="' + log.size + '" title="View"><i class="fas fa-eye"></i></button>' +
                                '<button class="btn btn-xs btn-success download-log-btn mr-1" data-file="' + escapeHtml(log.filename) + '" title="Download"><i class="fas fa-download"></i></button>' +
                                '<button class="btn btn-xs btn-danger delete-log-btn" data-file="' + escapeHtml(log.filename) + '" title="Delete"><i class="fas fa-trash-alt"></i></button>' +
                            '</td>' +
                            '</tr>';
                    }
                    tbody.html(rows);

                    logsTable = $("#breakout-logs-table").DataTable({
                        order: [[4, "desc"]],
                        pageLength: 15,
                        lengthMenu: [15, 25, 50],
                        columnDefs: [{ orderable: false, targets: [0, 6] }],
                        language: { emptyTable: "No breakout log files found." }
                    });

                    // Reset selection state after table rebuild
                    $("#selectAllLogsCheckbox").prop("checked", false).prop("indeterminate", false);
                    updateBulkDeleteBtn();
                }

                // --- Load all logs (single API call) ---

                function loadAllLogs() {
                    $.ajax({
                        type: "GET",
                        url: "{{ path('breakoutLogsList') }}",
                        dataType: "json",
                        success: function (data) {
                            allLogs = data.logs || [];
                            allDictionaries = data.dictionaries || [];
                            renderDictList();
                            renderLogsTable();
                        },
                        error: function (response) {
                            if (response.status === 401 || response.status === 405) {
                                window.location.href = "{{ path('logout') }}";
                            } else {
                                showAlert("Failed to load breakout logs.", "alert alert-danger");
                            }
                        }
                    });
                }

                // Initial load
                loadAllLogs();

                // Refresh
                $("#refresh-logs-btn").on("click", function () {
                    selectedDict = "";
                    $("#logs-dict-search").val("");
                    loadAllLogs();
                });

                // --- Sidebar interactions ---

                // Click dictionary
                $(document).on("click", "#logs-dict-list .list-group-item", function (e) {
                    e.preventDefault();
                    selectedDict = $(this).data("dict") || "";
                    renderDictList();
                    renderLogsTable();
                });

                // Search dictionaries (re-render filtered list)
                $("#logs-dict-search").on("input", function () {
                    var q = $(this).val().toLowerCase();
                    var counts = buildDictCounts();
                    var html = '<a href="#" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center' +
                        (selectedDict === "" ? " active" : "") + '" data-dict="">' +
                        'All Dictionaries <span class="badge badge-pill ' +
                        (selectedDict === "" ? "badge-light" : "badge-primary") + '">' + allLogs.length + '</span></a>';
                    for (var i = 0; i < allDictionaries.length; i++) {
                        var d = allDictionaries[i];
                        if (q && d.toLowerCase().indexOf(q) === -1) continue;
                        var isActive = (selectedDict === d);
                        var cnt = counts[d] || 0;
                        html += '<a href="#" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center' +
                            (isActive ? " active" : "") + '" data-dict="' + escapeHtml(d) + '">' +
                            escapeHtml(d) + ' <span class="badge badge-pill ' +
                            (isActive ? "badge-light" : "badge-primary") + '">' + cnt + '</span></a>';
                    }
                    $("#logs-dict-list").html(html);
                });

                // --- Pro Modal ---

                $(document).on("click", ".view-log-btn", function () {
                    var btn = $(this);
                    var filename = btn.data("file");
                    var dict = btn.data("dict") || "";
                    var type = btn.data("type") || "";
                    var date = btn.data("date") || "";
                    var size = btn.data("size") || 0;

                    // Populate header metadata
                    $("#view-log-filename").text(filename);
                    $("#view-log-dict").text(dict);
                    var $typeBadge = $("#view-log-type");
                    if (type === "manual") {
                        $typeBadge.text("Manual").removeClass("badge-primary").addClass("badge-warning");
                    } else {
                        $typeBadge.text("Scheduled").removeClass("badge-warning").addClass("badge-primary");
                    }
                    $("#view-log-date").text(date);
                    $("#view-log-size").text(formatSize(size));
                    $("#view-log-lines").text("");
                    $("#view-log-status").text("");

                    // Reset state
                    currentLogContent = "";
                    $("#view-log-body").empty();
                    $("#view-log-loading").show();
                    $("#view-log-wrapper").removeClass("cspro-log-wrap");
                    $("#log-wrap-btn").removeClass("active");
                    $("#view-log-modal").data("file", filename);
                    $("#view-log-modal").modal("show");

                    $.ajax({
                        type: "GET",
                        url: "{{ path('breakoutLogContent') }}?file=" + encodeURIComponent(filename),
                        dataType: "text",
                        success: function (content) {
                            currentLogContent = content;
                            var lines = content.split("\n");
                            // Build line-numbered table via string concatenation (perf)
                            var html = "";
                            for (var i = 0; i < lines.length; i++) {
                                html += '<tr><td class="cspro-log-line-num">' + (i + 1) +
                                    '</td><td class="cspro-log-line-text"><pre>' +
                                    escapeHtml(lines[i]) + '</pre></td></tr>';
                            }
                            $("#view-log-body").html(html);
                            $("#view-log-lines").text(lines.length + " lines");
                            $("#view-log-status").text("Loaded " + lines.length + " lines");
                            $("#view-log-loading").hide();
                        },
                        error: function () {
                            $("#view-log-body").html('<tr><td colspan="2" class="text-center text-danger p-4">Failed to load log content.</td></tr>');
                            $("#view-log-loading").hide();
                            $("#view-log-status").text("Error loading content");
                        }
                    });
                });

                // --- Toolbar buttons ---

                // Copy to clipboard
                $("#log-copy-btn").on("click", function () {
                    if (!currentLogContent) return;
                    var $btn = $(this);
                    if (navigator.clipboard && navigator.clipboard.writeText) {
                        navigator.clipboard.writeText(currentLogContent).then(function () {
                            $btn.html('<i class="fas fa-check"></i> Copied');
                            setTimeout(function () { $btn.html('<i class="fas fa-copy"></i> Copy'); }, 2000);
                        });
                    } else {
                        // Fallback
                        var ta = document.createElement("textarea");
                        ta.value = currentLogContent;
                        ta.style.position = "fixed";
                        ta.style.left = "-9999px";
                        document.body.appendChild(ta);
                        ta.select();
                        document.execCommand("copy");
                        document.body.removeChild(ta);
                        $btn.html('<i class="fas fa-check"></i> Copied');
                        setTimeout(function () { $btn.html('<i class="fas fa-copy"></i> Copy'); }, 2000);
                    }
                });

                // Download from modal
                $("#log-download-btn").on("click", function () {
                    var filename = $("#view-log-modal").data("file");
                    if (filename) {
                        window.open("{{ path('breakoutLogContent') }}?file=" + encodeURIComponent(filename), "_blank");
                    }
                });

                // Download from table
                $(document).on("click", ".download-log-btn", function () {
                    var filename = $(this).data("file");
                    window.open("{{ path('breakoutLogContent') }}?file=" + encodeURIComponent(filename), "_blank");
                });

                // Word wrap toggle
                $("#log-wrap-btn").on("click", function () {
                    $(this).toggleClass("active");
                    $("#view-log-wrapper").toggleClass("cspro-log-wrap");
                });

                // Scroll top / bottom
                $("#log-scroll-top-btn").on("click", function () {
                    $("#view-log-wrapper").scrollTop(0);
                });
                $("#log-scroll-bottom-btn").on("click", function () {
                    var el = $("#view-log-wrapper")[0];
                    el.scrollTop = el.scrollHeight;
                });

                // --- Delete log ---

                $(document).on("click", ".delete-log-btn", function () {
                    var filename = $(this).data("file");
                    $("#delete-log-filename").text(filename);
                    $("#delete-log-modal").data("file", filename).modal("show");
                });

                $("#confirm-delete-log").on("click", function () {
                    var filename = $("#delete-log-modal").data("file");
                    if (!filename) return;
                    var $btn = $(this);
                    $btn.prop("disabled", true).html('<i class="fas fa-spinner fa-spin"></i> Deleting…');
                    $.ajax({
                        type: "DELETE",
                        url: "{{ path('breakoutLogDelete') }}",
                        contentType: "application/json",
                        data: JSON.stringify({ file: filename }),
                        dataType: "json",
                        success: function (data) {
                            $("#delete-log-modal").modal("hide");
                            showAlert(data.description || "Log deleted.", "alert alert-success");
                            loadAllLogs();
                        },
                        error: function (response) {
                            $("#delete-log-modal").modal("hide");
                            if (response.status === 401 || response.status === 405) {
                                window.location.href = "{{ path('logout') }}";
                            } else {
                                var msg = "Failed to delete log.";
                                try { msg = JSON.parse(response.responseText).description || msg; } catch (e) {}
                                showAlert(msg, "alert alert-danger");
                            }
                        },
                        complete: function () {
                            $btn.prop("disabled", false).html('<i class="fas fa-trash-alt"></i> Delete');
                        }
                    });
                });

                // --- Bulk selection & delete ---

                function updateBulkDeleteBtn() {
                    var selCount = $(".log-select:checked").length;
                    var $btn = $("#delete-selected-logs-btn");
                    if (selCount > 0) {
                        $btn.prop("disabled", false).html('<i class="fas fa-trash-alt"></i> Delete Selected (' + selCount + ')');
                    } else {
                        $btn.prop("disabled", true).html('<i class="fas fa-trash-alt"></i> Delete Selected');
                    }
                }

                function updateSelectAllCheckbox() {
                    var total = $(".log-select").length;
                    var checked = $(".log-select:checked").length;
                    var cb = $("#selectAllLogsCheckbox")[0];
                    if (total === 0) {
                        cb.checked = false;
                        cb.indeterminate = false;
                    } else if (checked === total) {
                        cb.checked = true;
                        cb.indeterminate = false;
                    } else if (checked > 0) {
                        cb.checked = false;
                        cb.indeterminate = true;
                    } else {
                        cb.checked = false;
                        cb.indeterminate = false;
                    }
                }

                $(document).on("change", ".log-select", function () {
                    updateSelectAllCheckbox();
                    updateBulkDeleteBtn();
                });

                $("#selectAllLogsCheckbox").on("click", function () {
                    var isChecked = $(this).is(":checked");
                    $(".log-select").prop("checked", isChecked);
                    updateBulkDeleteBtn();
                });

                $("#delete-selected-logs-btn").on("click", function () {
                    var selected = $(".log-select:checked");
                    if (selected.length === 0) return;
                    $("#bulk-delete-count").text(selected.length);
                    $("#delete-logs-bulk-modal").modal("show");
                });

                $("#confirm-delete-logs-bulk").on("click", function () {
                    var files = [];
                    $(".log-select:checked").each(function () {
                        files.push($(this).val());
                    });
                    if (files.length === 0) return;
                    var $btn = $(this);
                    $btn.prop("disabled", true).html('<i class="fas fa-spinner fa-spin"></i> Deleting…');
                    $.ajax({
                        type: "POST",
                        url: "{{ path('breakoutLogDeleteBulk') }}",
                        contentType: "application/json",
                        data: JSON.stringify({ files: files }),
                        dataType: "json",
                        success: function (data) {
                            $("#delete-logs-bulk-modal").modal("hide");
                            showAlert(data.description || "Logs deleted.", "alert alert-success");
                            loadAllLogs();
                        },
                        error: function (response) {
                            $("#delete-logs-bulk-modal").modal("hide");
                            if (response.status === 401 || response.status === 405) {
                                window.location.href = "{{ path('logout') }}";
                            } else {
                                var msg = "Bulk delete failed.";
                                try { msg = JSON.parse(response.responseText).description || msg; } catch (e) {}
                                showAlert(msg, "alert alert-danger");
                            }
                        },
                        complete: function () {
                            $btn.prop("disabled", false).html('<i class="fas fa-trash-alt"></i> Delete All Selected');
                        }
                    });
                });
            })();

            // =================================================================
            // Application Log (ui.log)
            // =================================================================
            (function () {
                var appLogFilename = "";
                var appLogLines = 0;
                var appLogSize = 0;
                var appLogRawContent = "";

                function formatSize(b) {
                    if (b < 1024) return b + ' B';
                    if (b < 1048576) return (b / 1024).toFixed(1) + ' KB';
                    return (b / 1048576).toFixed(1) + ' MB';
                }

                function escapeHtml(str) {
                    var div = document.createElement("div");
                    div.appendChild(document.createTextNode(str));
                    return div.innerHTML;
                }

                function loadAppLogInfo() {
                    $("#applog-info").html('<i class="fas fa-spinner fa-spin"></i> Checking log file…').show();
                    $("#applog-viewer").hide();
                    $("#applog-wrapper").hide();
                    $("#load-applog-btn").hide();
                    $("#delete-applog-btn").hide();
                    $.ajax({
                        type: "GET",
                        url: "{{ path('appLogInfo') }}",
                        dataType: "json",
                        global: false,
                        success: function (data) {
                            if (!data.exists) {
                                $("#applog-info").html('<i class="fas fa-exclamation-circle text-warning"></i> No application log file found (ui.log).').show();
                                return;
                            }
                            appLogFilename = data.filename;
                            appLogLines = data.lines;
                            appLogSize = data.size;
                            $("#applog-info").hide();
                            $("#applog-filename").text(data.filename);
                            $("#applog-meta").text(data.lines + " lines — " + formatSize(data.size) + " — modified " + data.modified);
                            $("#applog-viewer").show();
                            $("#load-applog-btn").show();
                            $("#delete-applog-btn").show();
                        },
                        error: function (response) {
                            if (response.status === 401 || response.status === 405) {
                                window.location.href = "{{ path('logout') }}";
                            } else {
                                $("#applog-info").html('<i class="fas fa-exclamation-triangle text-danger"></i> Failed to check log file.').show();
                            }
                        }
                    });
                }

                function loadAppLogContent() {
                    var $btn = $("#load-applog-btn");
                    $btn.prop("disabled", true).html('<i class="fas fa-spinner fa-spin"></i> Loading…');
                    $.ajax({
                        type: "GET",
                        url: "{{ path('appLogInfo') }}?full=1",
                        dataType: "json",
                        global: false,
                        success: function (data) {
                            if (!data.content) {
                                $("#applog-wrapper").show();
                                $("#applog-body").html('<tr><td class="text-center text-muted p-4">Log file is empty.</td></tr>');
                                $btn.hide();
                                return;
                            }
                            appLogRawContent = data.content;
                            var lines = data.content.split("\n");
                            var html = "";
                            for (var i = 0; i < lines.length; i++) {
                                html += '<tr><td class="cspro-log-line-num">' + (i + 1) +
                                    '</td><td class="cspro-log-line-text"><pre>' +
                                    escapeHtml(lines[i]) + '</pre></td></tr>';
                            }
                            $("#applog-body").html(html);
                            $("#applog-wrapper").show();
                            $("#applog-tools").show();
                            $btn.hide();
                            // Scroll to bottom
                            var el = $("#applog-wrapper")[0];
                            el.scrollTop = el.scrollHeight;
                        },
                        error: function (response) {
                            if (response.status === 401 || response.status === 405) {
                                window.location.href = "{{ path('logout') }}";
                            } else {
                                $("#applog-wrapper").show();
                                $("#applog-body").html('<tr><td class="text-center text-danger p-4">Failed to load log content.</td></tr>');
                            }
                        },
                        complete: function () {
                            $btn.prop("disabled", false).html('<i class="fas fa-eye"></i> View Full Log');
                        }
                    });
                }

                // Load info when tab is shown
                $('a[data-toggle="tab"][href="#tab-applog"]').on("shown.bs.tab", function () {
                    loadAppLogInfo();
                });

                $("#refresh-applog-btn").on("click", function () {
                    $("#applog-wrapper").hide();
                    $("#applog-tools").hide();
                    $("#applog-body").empty();
                    appLogRawContent = "";
                    loadAppLogInfo();
                });

                $("#load-applog-btn").on("click", function () {
                    loadAppLogContent();
                });

                // Toggle word wrap
                $("#toggle-applog-wrap").on("click", function () {
                    var $wrapper = $("#applog-wrapper");
                    $wrapper.toggleClass("cspro-log-wrap");
                    var isWrapped = $wrapper.hasClass("cspro-log-wrap");
                    $(this).toggleClass("btn-outline-secondary", !isWrapped)
                           .toggleClass("btn-secondary", isWrapped);
                });

                // Copy log content to clipboard
                $("#copy-applog-btn").on("click", function () {
                    var $btn = $(this);
                    if (!appLogRawContent) return;
                    if (navigator.clipboard && navigator.clipboard.writeText) {
                        navigator.clipboard.writeText(appLogRawContent).then(function () {
                            $btn.html('<i class="fas fa-check"></i> Copied!');
                            setTimeout(function () { $btn.html('<i class="fas fa-copy"></i> Copy'); }, 2000);
                        });
                    } else {
                        var ta = document.createElement("textarea");
                        ta.value = appLogRawContent;
                        ta.style.position = "fixed";
                        ta.style.opacity = "0";
                        document.body.appendChild(ta);
                        ta.select();
                        document.execCommand("copy");
                        document.body.removeChild(ta);
                        $btn.html('<i class="fas fa-check"></i> Copied!');
                        setTimeout(function () { $btn.html('<i class="fas fa-copy"></i> Copy'); }, 2000);
                    }
                });

                // Delete application log
                $("#delete-applog-btn").on("click", function () {
                    $("#delete-applog-filename").text(appLogFilename);
                    $("#delete-applog-meta").text(appLogLines + " lines — " + formatSize(appLogSize));
                    $("#delete-applog-modal").modal("show");
                });

                $("#confirm-delete-applog").on("click", function () {
                    var $btn = $(this);
                    $btn.prop("disabled", true).html('<i class="fas fa-spinner fa-spin"></i> Deleting…');
                    $.ajax({
                        type: "DELETE",
                        url: "{{ path('appLogDelete') }}",
                        dataType: "json",
                        global: false,
                        success: function (data) {
                            $("#delete-applog-modal").modal("hide");
                            showAlert(data.description || "Application log deleted.", "alert alert-success");
                            $("#applog-wrapper").hide();
                            $("#applog-body").empty();
                            loadAppLogInfo();
                        },
                        error: function (response) {
                            $("#delete-applog-modal").modal("hide");
                            if (response.status === 401 || response.status === 405) {
                                window.location.href = "{{ path('logout') }}";
                            } else {
                                var msg = "Failed to delete application log.";
                                try { msg = JSON.parse(response.responseText).description || msg; } catch (e) {}
                                showAlert(msg, "alert alert-danger");
                            }
                        },
                        complete: function () {
                            $btn.prop("disabled", false).html('<i class="fas fa-trash-alt"></i> Delete');
                        }
                    });
                });
            })();

    </script>
{% endblock %}
{# scripts #}
