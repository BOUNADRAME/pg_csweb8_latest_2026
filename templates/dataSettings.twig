            function styleDifferences(a, b) {
                var as = getComputedStyle(a, null);
                var bs = getComputedStyle(b, null);
                var r = [];
                for (var i in as)
                    if (as[i] !== bs[i])
                        r.push(i + ' differs: ' + as[i] + ' | ' + bs[i]);
                return r.join('\n');
            }

