                                    <span class="badge badge-info cron-example mr-1 mb-1" style="cursor:pointer" data-cron="0 * * * *" data-target="#edit-schedule-cron">Every hour</span>
                                    <span class="badge badge-info cron-example mr-1 mb-1" style="cursor:pointer" data-cron="0 2 * * *" data-target="#edit-schedule-cron">Daily 02:00</span>
                                    <span class="badge badge-info cron-example mr-1 mb-1" style="cursor:pointer" data-cron="0 8 * * *" data-target="#edit-schedule-cron">Daily 08:00</span>
                                    <span class="badge badge-info cron-example mr-1 mb-1" style="cursor:pointer" data-cron="30 1 * * *" data-target="#edit-schedule-cron">Daily 01:30</span>
                                    <span class="badge badge-info cron-example mr-1 mb-1" style="cursor:pointer" data-cron="0 0 * * 1-5" data-target="#edit-schedule-cron">Weekdays 00:00</span>
