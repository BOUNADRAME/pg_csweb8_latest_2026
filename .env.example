# ========================================
# CSWeb Community Platform - Environment Variables
# ========================================
# Copy this file to .env and fill with your values
# Generate secure secrets with: openssl rand -base64 32

# ========================================
# GENERAL
# ========================================
APP_ENV=prod
APP_SECRET=change_me_generate_with_openssl_rand_hex_32
APP_DEBUG=false

# ========================================
# SECURITY
# ========================================
# JWT Secret for API authentication
# Generate with: openssl rand -base64 32
JWT_SECRET=change_me_generate_with_openssl_rand_base64_32
JWT_EXPIRATION=86400000

# ========================================
# MYSQL (CSWeb Metadata)
# ========================================
# CSWeb uses MySQL for metadata (dictionaries, users, cases)
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=csweb_metadata
MYSQL_USER=csweb
MYSQL_PASSWORD=change_me_secure_password_here
MYSQL_ROOT_PASSWORD=change_me_secure_root_password_here

# Database URL (Symfony format)
DATABASE_URL=mysql://${MYSQL_USER}:${MYSQL_PASSWORD}@${MYSQL_HOST}:${MYSQL_PORT}/${MYSQL_DATABASE}

# ========================================
# POSTGRESQL (Breakout Analytics - Default)
# ========================================
# PostgreSQL is recommended for breakout analytics (performance + JSON support)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DATABASE=csweb_analytics
POSTGRES_USER=csweb_analytics
POSTGRES_PASSWORD=change_me_secure_password_here

# PostgreSQL URL (for breakout default)
POSTGRES_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DATABASE}

# ========================================
# SQL SERVER (Optional - Enterprise)
# ========================================
# Uncomment if using SQL Server for breakout
# SQLSERVER_HOST=sqlserver
# SQLSERVER_PORT=1433
# SQLSERVER_DATABASE=csweb_analytics
# SQLSERVER_USER=sa
# SQLSERVER_PASSWORD=YourStrong!Passw0rd

# ========================================
# WEBHOOKS CONFIGURATION
# ========================================
# Shared secret token for webhook authentication
# IMPORTANT: Must match between Kairos API and CSWeb webhooks
# Generate with: openssl rand -base64 32
WEBHOOK_TOKEN=change_me_generate_with_openssl_rand_base64_32

# Webhook URLs (internal - Docker network)
WEBHOOK_BREAKOUT_URL=http://csweb/api/breakout-webhook.php
WEBHOOK_LOG_READER_URL=http://csweb/api/log-reader-webhook.php
WEBHOOK_DICTIONARY_SCHEMA_URL=http://csweb/api/dictionary-schema-webhook.php

# Webhook timeout (seconds)
WEBHOOK_TIMEOUT=300

# ========================================
# BREAKOUT CONFIGURATION
# ========================================
# Default database type for new dictionaries (postgresql|mysql|sqlserver)
DEFAULT_BREAKOUT_DB_TYPE=postgresql

# Default cron expression for breakout jobs
# Examples:
#   0 0 1 * * ?      = Every day at 1 AM
#   0 30 2 * * ?     = Every day at 2:30 AM
#   0 */10 * * * ?   = Every 10 minutes
DEFAULT_BREAKOUT_CRON=0 0 1 * * ?

# Auto-seed breakout jobs on startup
# If true, creates scheduler jobs for all dictionaries on first start
BREAKOUT_AUTO_SEED=true

# Max breakout duration (seconds)
BREAKOUT_MAX_DURATION=600

# Breakout batch size (number of cases processed at once)
BREAKOUT_BATCH_SIZE=1000

# ========================================
# SCHEDULER CONFIGURATION
# ========================================
# Enable/disable scheduler service
SCHEDULER_ENABLED=true

# Scheduler check interval (seconds)
SCHEDULER_CHECK_INTERVAL=60

# Max concurrent jobs
SCHEDULER_MAX_CONCURRENT_JOBS=5

# Job retry on failure
SCHEDULER_RETRY_ENABLED=true
SCHEDULER_RETRY_MAX_ATTEMPTS=3
SCHEDULER_RETRY_DELAY_SECONDS=300

# ========================================
# LOGS & MONITORING
# ========================================
# Log level (DEBUG|INFO|WARNING|ERROR|CRITICAL)
LOG_LEVEL=INFO

# Log rotation (days)
LOG_ROTATION_DAYS=7

# Log max size (MB)
LOG_MAX_SIZE_MB=500

# Enable logs streaming (SSE - Server-Sent Events)
LOGS_STREAMING_ENABLED=true

# Log file path
LOG_FILE_PATH=/var/www/csweb/var/logs/app.log

# ========================================
# API CONFIGURATION
# ========================================
# API rate limiting (requests per minute per user)
API_RATE_LIMIT=60

# API timeout (seconds)
API_TIMEOUT=30

# CORS allowed origins (comma-separated)
# Examples: http://localhost:3000,http://localhost:8080,https://csweb.example.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# API base URL (for documentation)
API_BASE_URL=http://localhost:8080/api

# ========================================
# NOTIFICATIONS
# ========================================
# Email notifications (SMTP)
MAILER_DSN=smtp://user:pass@smtp.example.com:587
MAIL_FROM_ADDRESS=noreply@csweb.example.com
MAIL_FROM_NAME=CSWeb Community

# Slack webhook URL (optional)
# Get from: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# Microsoft Teams webhook URL (optional)
# Get from: https://docs.microsoft.com/en-us/microsoftteams/platform/webhooks-and-connectors/how-to/add-incoming-webhook
TEAMS_WEBHOOK_URL=

# Notification settings
NOTIFICATIONS_ENABLED=true
NOTIFICATIONS_ON_SUCCESS=false
NOTIFICATIONS_ON_FAILURE=true

# ========================================
# MONITORING (Prometheus/Grafana)
# ========================================
# Enable Prometheus metrics
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090

# Grafana admin password
GRAFANA_ADMIN_PASSWORD=change_me_admin_password_here
GRAFANA_PORT=3001

# ========================================
# BACKUP CONFIGURATION
# ========================================
# Auto backup enabled
BACKUP_ENABLED=true

# Backup cron expression
BACKUP_CRON=0 0 2 * * *

# Backup retention (days)
BACKUP_RETENTION_DAYS=30

# Backup destination (local|s3|gcs)
BACKUP_DESTINATION=local
BACKUP_LOCAL_PATH=/var/backups/csweb

# AWS S3 Configuration (if BACKUP_DESTINATION=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_REGION=us-east-1
AWS_S3_PREFIX=csweb-backups/

# Google Cloud Storage (if BACKUP_DESTINATION=gcs)
GCS_PROJECT_ID=
GCS_BUCKET=
GCS_CREDENTIALS_PATH=/path/to/credentials.json

# ========================================
# CACHING
# ========================================
# Cache driver (apcu|redis|memcached|filesystem)
CACHE_DRIVER=filesystem

# Redis configuration (if CACHE_DRIVER=redis)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# Cache TTL (seconds)
CACHE_TTL=3600

# ========================================
# SESSION
# ========================================
# Session lifetime (seconds)
SESSION_LIFETIME=7200

# Session driver (file|database|redis)
SESSION_DRIVER=file

# ========================================
# FILE STORAGE
# ========================================
# Storage driver (local|s3|gcs)
STORAGE_DRIVER=local

# Local storage path
STORAGE_LOCAL_PATH=/var/www/csweb/var/storage

# Max file upload size (MB)
MAX_UPLOAD_SIZE_MB=100

# ========================================
# CSPRO SYNC API
# ========================================
# CSPro sync server configuration (original CSWeb functionality)
CSPRO_SYNC_ENABLED=true
CSPRO_SYNC_MAX_FILE_SIZE_MB=50

# ========================================
# DEVELOPMENT / DEBUG
# ========================================
# Enable debug mode (development only)
DEBUG=false

# Enable Symfony profiler (development only)
SYMFONY_PROFILER=false

# Enable query logging (development only)
QUERY_LOG_ENABLED=false

# ========================================
# ADMIN PANEL (React Frontend)
# ========================================
# Admin panel URL
ADMIN_PANEL_URL=http://localhost:3000

# API URL for admin panel
REACT_APP_API_URL=http://localhost:8080/api

# ========================================
# SSL/TLS
# ========================================
# Enable HTTPS
HTTPS_ENABLED=false

# SSL certificate paths (for nginx)
SSL_CERTIFICATE_PATH=/etc/nginx/certs/cert.pem
SSL_CERTIFICATE_KEY_PATH=/etc/nginx/certs/key.pem

# Force HTTPS redirect
FORCE_HTTPS=false

# ========================================
# TIMEZONE
# ========================================
# Application timezone
APP_TIMEZONE=Africa/Dakar

# Database timezone
DB_TIMEZONE=UTC

# ========================================
# LOCALE/LANGUAGE
# ========================================
# Default locale (fr|en)
APP_LOCALE=fr

# Available locales (comma-separated)
AVAILABLE_LOCALES=fr,en

# ========================================
# PERFORMANCE
# ========================================
# PHP memory limit
PHP_MEMORY_LIMIT=512M

# PHP max execution time (seconds)
PHP_MAX_EXECUTION_TIME=300

# PHP upload max filesize
PHP_UPLOAD_MAX_FILESIZE=100M

# PHP post max size
PHP_POST_MAX_SIZE=100M

# ========================================
# SECURITY HEADERS
# ========================================
# Content Security Policy (CSP)
CSP_ENABLED=true
CSP_POLICY=default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline';

# ========================================
# ANALYTICS (Optional)
# ========================================
# Google Analytics tracking ID
GOOGLE_ANALYTICS_ID=

# Matomo tracking
MATOMO_URL=
MATOMO_SITE_ID=

# ========================================
# FEATURE FLAGS
# ========================================
# Enable/disable features
FEATURE_BREAKOUT_SELECTOR=true
FEATURE_SCHEDULER_UI=true
FEATURE_LOGS_STREAMING=true
FEATURE_MULTI_DATABASE=true
FEATURE_GRAFANA=false
FEATURE_AI_ASSISTANT=false

# ========================================
# GENERATE SECURE SECRETS
# ========================================
# Run these commands to generate secure values:
#
# APP_SECRET:
#   openssl rand -hex 32
#
# JWT_SECRET, WEBHOOK_TOKEN:
#   openssl rand -base64 32
#
# MYSQL_PASSWORD, POSTGRES_PASSWORD:
#   openssl rand -base64 24
#
# GRAFANA_ADMIN_PASSWORD:
#   openssl rand -base64 16

# ========================================
# DOCKER CONFIGURATION
# ========================================
# Docker Compose project name
COMPOSE_PROJECT_NAME=csweb-community

# Docker image tag
DOCKER_IMAGE_TAG=latest

# ========================================
# NOTES
# ========================================
# 1. NEVER commit this file with real credentials to Git
# 2. Use .env for local development, .env.prod for production
# 3. Keep .env.example updated with new variables
# 4. Use strong, unique passwords for all services
# 5. Rotate secrets regularly (at least every 90 days)
