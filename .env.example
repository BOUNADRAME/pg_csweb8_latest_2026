# ============================================================================
# CSWeb Community Platform - Configuration Template
# ============================================================================
# Version: 2.0.0
# Date: 14 Mars 2026
# Author: Bouna DRAME
#
# IMPORTANT:
#   1. Copier ce fichier vers .env : cp .env.example .env
#   2. Modifier les valeurs selon votre environnement
#   3. Ne JAMAIS committer .env (contient mots de passe)
#
# ARCHITECTURE FLEXIBLE:
#   - Mode LOCAL: Docker containers pour DB breakout (développement/test)
#   - Mode REMOTE: Connexion serveur distant (production)
#   - Support: PostgreSQL, MySQL, SQL Server
# ============================================================================

# ============================================================================
# 🎯 CONFIGURATION BREAKOUT (ESSENTIEL - À CONFIGURER EN PREMIER)
# ============================================================================

# Mode de déploiement de la base de données breakout
# local  = Docker containers (développement, test)
# remote = Serveur distant (production, RGPH5, etc.)
BREAKOUT_MODE=local

# Type de base de données pour le breakout
# postgresql = PostgreSQL (recommandé pour analytics)
# mysql      = MySQL (compatible, performant)
# sqlserver  = SQL Server (RGPH5 Sénégal, production enterprise)
BREAKOUT_DB_TYPE=postgresql

# ============================================================================
# 📦 APPLICATION
# ============================================================================
APP_ENV=prod
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_SECRET=

# Ports
CSWEB_PORT=8080

# ============================================================================
# 🗄️ MySQL - Métadonnées CSWeb (TOUJOURS LOCAL - NE PAS MODIFIER)
# ============================================================================
# Cette base de données est créée automatiquement par setup.php
# Elle contient les métadonnées CSWeb (users, dictionaries, oauth_clients)
# ⚠️ TOUJOURS sur la même machine que CSWeb (localhost ou container 'mysql')
# ⚠️ NE JAMAIS utiliser cette base pour le breakout !

MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=csweb_metadata
MYSQL_USER=csweb_user
MYSQL_PASSWORD=
MYSQL_ROOT_PASSWORD=

# ============================================================================
# 🐘 PostgreSQL - Breakout (si BREAKOUT_DB_TYPE=postgresql)
# ============================================================================

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DATABASE=csweb_analytics
POSTGRES_USER=csweb_analytics
POSTGRES_PASSWORD=

# ============================================================================
# 🐬 MySQL - Breakout (si BREAKOUT_DB_TYPE=mysql)
# ============================================================================

MYSQL_BREAKOUT_HOST=mysql-breakout
MYSQL_BREAKOUT_PORT=3307
MYSQL_BREAKOUT_DATABASE=csweb_breakout
MYSQL_BREAKOUT_USER=breakout_user
MYSQL_BREAKOUT_PASSWORD=

# ============================================================================
# 🏢 SQL Server - Breakout (si BREAKOUT_DB_TYPE=sqlserver)
# ============================================================================

SQLSERVER_HOST=sqlserver
SQLSERVER_PORT=1433
SQLSERVER_DATABASE=CSWeb_Analytics
SQLSERVER_USER=sa
SQLSERVER_PASSWORD=YourStrong!Passw0rd

# ============================================================================
# 🛠️ OUTILS DE DÉVELOPPEMENT (Optionnel)
# ============================================================================

PHPMYADMIN_PORT=8081
PGADMIN_PORT=8082
PGADMIN_EMAIL=admin@csweb.local
PGADMIN_PASSWORD=admin123

# ============================================================================
# 🔐 SÉCURITÉ
# ============================================================================

JWT_SECRET=
JWT_EXPIRATION=86400000
FILES_FOLDER=/var/www/html/files
API_URL=http://localhost:8080/api/

# ============================================================================
# 📊 LOGGING
# ============================================================================
CSWEB_LOG_LEVEL=error
CSWEB_PROCESS_CASES_LOG_LEVEL=error
MAX_EXECUTION_TIME=300

# ============================================================================
# ⚡ PERFORMANCE TUNING
# ============================================================================
# Ajuster ces valeurs selon votre charge (voir .claude/PERFORMANCE-TUNING.md)

# --- PHP ---
PHP_MEMORY_LIMIT=512M
PHP_MAX_EXECUTION_TIME=300
PHP_MAX_INPUT_TIME=300
PHP_UPLOAD_MAX_FILESIZE=100M
PHP_POST_MAX_SIZE=100M
PHP_SESSION_GC_MAXLIFETIME=7200
PHP_OPCACHE_MEMORY=128
PHP_OPCACHE_MAX_FILES=10000

# --- MySQL Metadata ---
MYSQL_MAX_CONNECTIONS=200
MYSQL_INNODB_BUFFER_POOL_SIZE=256M
MYSQL_INNODB_LOG_FILE_SIZE=64M
MYSQL_SLOW_QUERY_TIME=2
MYSQL_MAX_ALLOWED_PACKET=64M
MYSQL_THREAD_CACHE_SIZE=16
MYSQL_TABLE_OPEN_CACHE=2000
MYSQL_WAIT_TIMEOUT=28800

# --- PostgreSQL Breakout ---
PG_MAX_CONNECTIONS=200
PG_SHARED_BUFFERS=256MB
PG_EFFECTIVE_CACHE_SIZE=1GB
PG_WORK_MEM=4MB
PG_MAINTENANCE_WORK_MEM=64MB

# --- Apache MPM Prefork ---
APACHE_MAX_REQUEST_WORKERS=150
APACHE_SERVER_LIMIT=150
APACHE_KEEP_ALIVE_TIMEOUT=5
APACHE_MAX_KEEP_ALIVE_REQUESTS=100
APACHE_TIMEOUT=300
